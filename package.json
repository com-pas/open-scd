{
  "name": "openscd-monorepo",
  "version": "0.45.13",
  "description": "OpenSCD base distribution and plugins",
  "private": true,
  "scripts": {
    "clean": "lerna run clean",
    "build": "NODE_OPTIONS=--no-experimental-require-module npx nx run-many -t build --all",
    "doc": "lerna run doc",
    "test": "npx nx run-many -t test --all --parallel=false",
    "graph": "npx nx graph",
    "start": "lerna run start",
    "serve": "nx run @openscd/distribution:serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/com-pas/open-scd.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "husky": "9.1.7",
    "lerna": "7.4.2",
    "nx": "18.3.4",
    "playwright": "1.61.1",
    "rimraf": "5.0.10"
  },
  "optionalDependencies": {
    "@nx/nx-linux-x64-gnu": "18.3.4"
  }
}
